<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<div class="container mt-5 text-center">
    <div class="card shadow p-5">
        <div class="display-1 text-danger">
            <i class="bi bi-exclua-octagon"></i> 403
        </div>
        <h2 class="mt-3">Acesso Negado!</h2>
        <p class="lead text-muted">
            <%= mensagem %>
        </p>
        <hr>
        <p>Se você acha que isso é um erro, entre em contato com o administrador do sistema.</p>
        <a href="/" class="btn btn-primary btn-lg mt-3">
            <i class="bi bi-house-door"></i> Voltar para o Início
        </a>
    </div>
</div>
