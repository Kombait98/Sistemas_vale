<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <title>Gerenciar Usuários - Sistemas Vale</title>
</head>
<body>
    
    <%- include('../partials/navbar') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-people-fill"></i> Gerenciar Usuários e Permissões</h2>
            <a href="/vales" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Voltar ao Cadastro
            </a>
        </div>

        <form action="/usuarios/novo" method="POST" class="row g-3 mb-5 p-4 border rounded shadow-sm bg-light">
            <div class="col-md-3">
                <label class="form-label font-weight-bold">Login (Usuário)</label>
                <input type="text" name="login" class="form-control" placeholder="Ex: joao.silva" required>
            </div>
            <div class="col-md-3">
                <label class="form-label font-weight-bold">Nome Completo</label>
                <input type="text" name="nome" class="form-control" placeholder="Ex: João da Silva" required>
            </div>
            <div class="col-md-3">
                <label class="form-label font-weight-bold">Senha Inicial</label>
                <input type="password" name="senha" class="form-control" placeholder="Digite a senha" required>
            </div>
            <div class="col-md-2">
                <label class="form-label font-weight-bold">Nível</label>
                <select name="permissao" class="form-select">
                    <option value="colaborador">Colaborador</option>
                    <option value="admin">Gerente (Admin)</option>
                </select>
            </div>
            <div class="col-md-1 d-flex align-items-end">
                <button type="submit" class="btn btn-success w-100">Add</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle border">
                <thead class="table-dark">
                    <tr>
                        <th>Nome</th>
                        <th>Login</th>
                        <th>Permissão</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    <% usuarios.forEach(u => { %>
                        <tr>
                            <td><strong><%= u.nome %></strong></td>
                            <td><code><%= u.login %></code></td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" 
                                        onclick="abrirModalPermissoes('<%= u.id %>', '<%= JSON.stringify(u.permissoes) %>', '<%= u.permissao %>')">
                                    <i class="bi bi-shield-lock"></i> Permissões
                                </button>
                            </td>
                            <td>
                                <div class="d-flex gap-2 justify-content-center">
                                    <button type="button" class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#resetModal<%= u.id %>">
                                        <i class="bi bi-key"></i> Reset Senha
                                    </button>

                                    <% if (u.login !== 'admin') { %>
                                        <form action="/usuarios/deletar/<%= u.id %>" method="POST" onsubmit="return confirm('Excluir usuário permanentemente?')">
                                            <button class="btn btn-outline-danger btn-sm">
                                                <i class="bi bi-trash"></i> Excluir
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <span class="badge bg-secondary">Sistema</span>
                                    <% } %>
                                </div>

                                <div class="modal fade" id="resetModal<%= u.id %>" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <form action="/usuarios/reset-senha/<%= u.id %>" method="POST">
                                                <div class="modal-header bg-warning text-dark">
                                                    <h5 class="modal-title"><i class="bi bi-shield-lock"></i> Resetar Senha: <%= u.nome %></h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body text-start">
                                                    <div class="mb-3">
                                                        <label class="form-label">Nova Senha para <strong><%= u.login %></strong></label>
                                                        <input type="password" name="novaSenha" class="form-control" required placeholder="Digite a nova senha">
                                                    </div>
                                                    <div class="alert alert-warning py-2 small">
                                                        <i class="bi bi-exclamation-triangle"></i> Atenção: A senha será alterada imediatamente após a confirmação.
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                                    <button type="submit" class="btn btn-danger">Confirmar Reset</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
<div class="modal fade" id="modalPermissoes" tabindex="-1">
    <div class="modal-dialog">
        <form id="formPermissoes" method="POST">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Configurar Acessos</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-warning border-warning mb-3">
                        <h6><i class="bi bi-person-badge-fill"></i> Configurações de Sistema</h6>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="admin_geral" id="g_admin">
                            <label class="form-check-label fw-bold">Administrador Geral</label>
                            <small class="d-block text-muted">Permite gerenciar usuários, unidades e configurações globais.</small>
                        </div>
                    </div>
                <hr>
                    <div class="card mb-3 p-3">
                        <h6>Módulo Vales</h6>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" name="vales_acesso" id="v_acesso">
                            <label class="form-check-label">Habilitar Módulo</label>
                        </div>
                        <select name="vales_nivel" id="v_nivel" class="form-select form-select-sm">
                            <option value="colaborador">Colaborador (Apenas Lançar)</option>
                            <option value="gerente">Gerente (Autorizar/Pagar)</option>
                        </select>
                    </div>

                    <div class="card p-3">
                        <h6>Módulo Viagens (Travels)</h6>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" name="travels_acesso" id="t_acesso">
                            <label class="form-check-label">Habilitar Módulo</label>
                        </div>
                        <select name="travels_nivel" id="t_nivel" class="form-select form-select-sm">
                            <option value="colaborador">Colaborador</option>
                            <option value="gerente">Gerente</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Salvar Permissões</button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
function abrirModalPermissoes(id, permissoesStr, permissaoGlobal) {
    // 1. Converte a string JSON de volta para objeto
    const permissoes = JSON.parse(permissoesStr);
    const form = document.getElementById('formPermissoes');
    
    // 2. Define a rota de destino do formulário
    form.action = `/usuarios/permissoes/${id}`;

    // 3. LOGICA DO CHECKBOX ADMIN GERAL (O segredo está aqui)
    // Se a permissãoGlobal for exatamente 'admin', ele marca como true
    document.getElementById('g_admin').checked = (permissaoGlobal === 'admin');

    // 4. LOGICA DOS MÓDULOS
    document.getElementById('v_acesso').checked = permissoes.vales?.acesso || false;
    document.getElementById('v_nivel').value = permissoes.vales?.nivel || 'colaborador';
    
    document.getElementById('t_acesso').checked = permissoes.travels?.acesso || false;
    document.getElementById('t_nivel').value = permissoes.travels?.nivel || 'colaborador';

    // 5. Abre o modal do Bootstrap
    new bootstrap.Modal(document.getElementById('modalPermissoes')).show();
}
</script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>